# =============================================
# Qyra Environment Variables
# Copy this to .env and fill in your values
# =============================================

# App
APP_ENV=development
PORT=8080

# SurrealDB
SURREALDB_URL=ws://localhost:8000
SURREALDB_NS=qyra
SURREALDB_DB=qyra_db
SURREALDB_USER=root
SURREALDB_PASS=root

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# JWT (generate a strong random secret)
JWT_SECRET=change-me-to-a-strong-random-secret-min-32-chars

# Upstash Redis
REDIS_URL=https://your-upstash-url.upstash.io
REDIS_TOKEN=your-upstash-token
